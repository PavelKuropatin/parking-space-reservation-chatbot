# LLM (OpenAI-compatible endpoint — OpenAI, LM Studio, etc.)
OPENAI_LLM_URL=
OPENAI_LLM_API_KEY=
OPENAI_LLM_MODEL=

# Weaviate
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=parking_info
WEAVIATE_INIT_DATA_PATH=assets/static

# RAG tuning
RAG_CHUNK_SIZE=200
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=3

# PostgreSQL (app data: pricing, hours, availability, reservations)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PSWD=
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=2

# LangGraph checkpointer (conversation state; can point at the same PostgreSQL instance/db as above)
CHECKPOINTER_HOST=localhost
CHECKPOINTER_PORT=5432
CHECKPOINTER_DB=
CHECKPOINTER_USER=
CHECKPOINTER_PSWD=

# Admin notification mailbox (shared filesystem path between client.py and admin.py)
NOTIFICATION_PATH=/tmp/parking_notification

# MCP server (chatbot/mcp/mcp_server.py, exposed via docker-compose on port 8088)
MCP_URL=http://0.0.0.0:8088/mcp
MCP_CLIENT_TOKEN=admin-agent-token
